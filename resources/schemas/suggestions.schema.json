{"$schema": "http://json-schema.org/draft-07/schema#", "title": "Novel Companion AI Review Suggestions", "description": "AI 审稿建议结果", "type": "object", "required": ["schemaVersion", "taskId", "generatedAt", "sourceFiles", "suggestions"], "properties": {"schemaVersion": {"type": "integer", "minimum": 1}, "taskId": {"type": "string", "pattern": "^task-\\d{8}-\\d{3}$"}, "chapterId": {"type": "string", "pattern": "^ch\\d{3}$"}, "generatedAt": {"type": "string", "format": "date-time"}, "generator": {"type": "string"}, "summary": {"type": "object", "properties": {"critical": {"type": "integer", "minimum": 0}, "high": {"type": "integer", "minimum": 0}, "medium": {"type": "integer", "minimum": 0}, "low": {"type": "integer", "minimum": 0}}}, "sourceFiles": {"type": "array", "items": {"type": "string"}, "minItems": 1}, "suggestions": {"type": "array", "items": {"type": "object", "required": ["id", "type", "severity", "file", "original", "reason", "canAutoApply"], "properties": {"id": {"type": "string", "pattern": "^sug-\\d{3}$"}, "type": {"type": "string", "enum": ["typo", "grammar", "punctuation", "repetition", "logic", "character", "setting", "power", "pacing", "emotion", "suggestion"]}, "severity": {"type": "string", "enum": ["critical", "high", "medium", "low"]}, "file": {"type": "string"}, "original": {"type": "string", "minLength": 1}, "replacement": {"type": "string"}, "reason": {"type": "string", "minLength": 1}, "evidence": {"type": "array", "items": {"type": "string"}}, "occurrences": {"type": "integer", "minimum": 1}, "canAutoApply": {"type": "boolean"}}}}}}