{"$schema": "http://json-schema.org/draft-07/schema#", "title": "Novel Companion AI Task", "description": "AI 审稿任务元数据", "type": "object", "required": ["taskId", "type", "template", "createdAt", "trigger", "permission", "sourceFiles", "outputPath", "outputFiles", "schemaPath", "status"], "properties": {"taskId": {"type": "string", "pattern": "^task-\\d{8}-\\d{3}$"}, "type": {"type": "string", "enum": ["chapter_review", "paragraph_proofread", "consistency_check", "brainstorm", "summary_generate"]}, "template": {"type": "string"}, "createdAt": {"type": "string", "format": "date-time"}, "trigger": {"type": "string", "enum": ["manual", "timer", "wordcount", "stage"]}, "chapter": {"type": "string", "pattern": "^ch\\d{3}$"}, "aiPlugin": {"type": "string", "enum": ["kilo-code", "cline", "roo-code", "continue", "other"]}, "permission": {"type": "object", "required": ["mode", "can_modify_manuscript", "can_create_suggestions", "can_add_new_plot", "can_change_character_setting"], "properties": {"mode": {"type": "string", "enum": ["review_only", "suggest_revision", "rewrite_selected", "brainstorm"]}, "can_modify_manuscript": {"type": "boolean"}, "can_create_suggestions": {"type": "boolean"}, "can_rewrite_paragraphs": {"type": "boolean"}, "can_add_new_plot": {"type": "boolean"}, "can_change_character_setting": {"type": "boolean"}}}, "sourceFiles": {"type": "array", "items": {"type": "string"}, "minItems": 1}, "contextFiles": {"type": "array", "items": {"type": "string"}}, "outputPath": {"type": "string"}, "outputFiles": {"type": "array", "items": {"type": "string"}}, "schemaPath": {"type": "string"}, "status": {"type": "string", "enum": ["generated", "processing", "completed", "failed", "expired"]}}}