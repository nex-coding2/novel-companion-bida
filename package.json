        },
        "novelCompanion.aiDirect.enabled": {
          "type": "boolean",
          "default": false,
          "description": "是否启用 AI 直连（可选；启用后可一键校对，结果仍走审阅面板由作者确认）"
        },
        "novelCompanion.aiDirect.apiBaseUrl": {
          "type": "string",
          "default": "https://api.openai.com/v1",
          "description": "AI 直连 API 基础地址（OpenAI 兼容端点）"
        },
        "novelCompanion.aiDirect.apiModel": {
          "type": "string",
          "default": "gpt-4o-mini",
          "description": "AI 直连使用的模型名"
        }
      }
