        "novelCompanion.review.reminderEnabled": {
          "type": "boolean",
          "default": true,
          "description": "是否启用 AI 审稿提醒"
        },
        "novelCompanion.review.reminderMode": {
          "type": "string",
          "enum": [
            "statusbar",
            "notification"
          ],
          "enumDescriptions": [
            "状态栏",
            "通知弹窗"
          ],
          "default": "statusbar",
          "description": "提醒方式"
        },
        "novelCompanion.review.snoozeMinutes": {
          "type": "number",
          "default": 10,
          "description": "稍后提醒间隔（分钟）"
        },
        "novelCompanion.ai.plugin": {
          "type": "string",
          "enum": [
            "kilo-code",
            "cline",
            "roo-code",
            "continue",
            "other"
          ],
          "enumDescriptions": [
            "Kilo Code",
            "Cline",
            "Roo Code",
            "Continue",
            "其他"
          ],
          "default": "kilo-code",
          "description": "目标 AI 插件"
        },
        "novelCompanion.ai.defaultPermission": {
          "type": "string",
          "enum": [
            "review_only",
            "suggest_revision",
            "rewrite_selected",
            "brainstorm"
          ],
          "enumDescriptions": [
            "只审阅",
            "建议修订",
            "重写选中",
            "头脑风暴"
          ],
          "default": "suggest_revision",
          "description": "AI 任务默认权限级别"
        },
        "novelCompanion.localCheck.enabled": {
          "type": "boolean",
          "default": true,
          "description": "是否启用本地规则检查"
        },
        "novelCompanion.localCheck.repeatedWord": {
          "type": "boolean",
          "default": true,
          "description": "检测连续重复词"
        },
        "novelCompanion.localCheck.punctuation": {
          "type": "boolean",
          "default": true,
          "description": "检测标点异常"
        },
        "novelCompanion.localCheck.typoDict": {
          "type": "boolean",
          "default": true,
          "description": "使用常见错别字字典检测"
        },
        "novelCompanion.localCheck.longSentence": {
          "type": "boolean",
          "default": true,
          "description": "检测过长句子"
        },
        "novelCompanion.localCheck.longSentenceThreshold": {
          "type": "number",
          "default": 80,
          "description": "长句阈值（字数）"
        },
        "novelCompanion.localCheck.highFrequency": {
          "type": "boolean",
          "default": true,
          "description": "检测高频词（仅保存时运行）"
        },
        "novelCompanion.localCheck.highFrequencyThreshold": {
          "type": "number",
          "default": 20,
          "description": "高频词阈值（次数）"
        },
        "novelCompanion.localCheck.extraSpace": {
          "type": "boolean",
          "default": true,
          "description": "检测中文间多余空格"
        },
        "novelCompanion.ui.mode": {
          "type": "string",
          "enum": [
            "beginner",
            "expert"
          ],
          "enumDescriptions": [
            "新手（表单引导）",
            "专家（直接编辑文件）"
          ],
          "default": "beginner",
          "description": "界面模式"
        },
        "novelCompanion.statusBar.simpleMode": {
          "type": "boolean",
          "default": false,
          "description": "状态栏简化模式"
        },
        "novelCompanion.snapshot.maxCount": {
          "type": "number",
          "default": 30,
          "minimum": 1,
          "description": "每章保留的最大快照数（超出自动清理最旧）"
