{
  "name": "novel-companion",
  "displayName": "笔搭",
  "description": "VS Code 小说创作工作流助手，配合 Kilo Code 等 AI 插件辅助写作",
  "version": "0.2.0",
  "publisher": "novel-companion",
  "license": "MIT",
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "novel",
    "writing",
    "ai",
    "creative",
    "fiction",
    "小说"
  ],
  "main": "./dist/extension.js",
  "activationEvents": [
    "onStartupFinished"
  ],
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "novel-companion",
          "title": "笔搭",
          "icon": "resources/icons/novel.svg"
        }
      ],
      "panel": [
        {
          "id": "novel-companion-panel",
          "title": "创作工作流",
          "icon": "resources/icons/novel.svg"
        }
      ]
    },
    "views": {
      "novel-companion": [
        {
          "id": "novel-companion.bookshelf",
          "name": "作品架"
        },
        {
          "id": "novel-companion.novel-info",
          "name": "小说信息"
        },
        {
          "id": "novel-companion.outlines",
          "name": "章节大纲"
        },
        {
          "id": "novel-companion.drafts",
          "name": "正文"
        },
        {
          "id": "novel-companion.characters",
          "name": "人物"
        },
        {
          "id": "novel-companion.settings",
          "name": "设定"
        },
        {
          "id": "novel-companion.foreshadowing",
          "name": "伏笔"
        },
        {
          "id": "novel-companion.timeline",
          "name": "时间线"
        },
        {
          "id": "novel-companion.snippets",
          "name": "语料片段"
        },
        {
          "id": "novel-companion.trash",
          "name": "回收站"
        }
      ],
      "novel-companion-panel": [
        {
          "id": "novel-companion.workflow",
          "name": "创作工作流",
          "type": "webview"
        }
      ]
    },
    "commands": [
      {
        "command": "novelCompanion.project.create",
        "title": "新建小说项目",
        "category": "笔搭"
      },
      {
        "command": "novelCompanion.project.detect",
        "title": "检测当前项目",
        "category": "笔搭"
      },
      {
        "command": "novelCompanion.novel.openPremise",
