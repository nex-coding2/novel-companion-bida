        "title": "查看使用说明",
        "category": "笔搭"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "novelCompanion.bookshelf.refresh",
          "when": "view == novel-companion.bookshelf",
          "group": "navigation"
        },
        {
          "command": "novelCompanion.chapter.create",
          "when": "view == novel-companion.outlines",
          "group": "navigation"
        },
        {
          "command": "novelCompanion.volume.create",
          "when": "view == novel-companion.outlines",
          "group": "navigation"
        },
        {
          "command": "novelCompanion.novel.export",
          "when": "view == novel-companion.outlines",
          "group": "overflow"
        },
        {
          "command": "novelCompanion.novel.searchReplace",
          "when": "view == novel-companion.outlines",
          "group": "overflow"
        },
        {
          "command": "novelCompanion.character.create",
          "when": "view == novel-companion.characters",
          "group": "navigation"
        },
        {
          "command": "novelCompanion.setting.create",
          "when": "view == novel-companion.settings",
          "group": "navigation"
        },
        {
          "command": "novelCompanion.foreshadowing.create",
          "when": "view == novel-companion.foreshadowing",
          "group": "navigation"
        },
        {
          "command": "novelCompanion.foreshadowing.openFile",
          "when": "view == novel-companion.foreshadowing",
          "group": "navigation"
        },
        {
          "command": "novelCompanion.timeline.create",
          "when": "view == novel-companion.timeline",
          "group": "navigation"
        },
        {
          "command": "novelCompanion.timeline.regenerate",
          "when": "view == novel-companion.timeline",
          "group": "navigation"
        },
        {
          "command": "novelCompanion.timeline.openFile",
          "when": "view == novel-companion.timeline",
          "group": "overflow"
        },
        {
          "command": "novelCompanion.snippet.create",
          "when": "view == novel-companion.snippets",
          "group": "navigation"
        },
        {
          "command": "novelCompanion.snippet.search",
          "when": "view == novel-companion.snippets",
          "group": "navigation"
        },
        {
          "command": "novelCompanion.trash.purgeAll",
          "when": "view == novel-companion.trash",
          "group": "overflow"
        },
        {
          "command": "novelCompanion.trash.cleanup",
          "when": "view == novel-companion.trash",
          "group": "overflow"
        },
        {
          "command": "novelCompanion.consistency.run",
          "when": "view == novel-companion.outlines",
          "group": "overflow"
        },
        {
          "command": "novelCompanion.readthrough.open",
          "when": "view == novel-companion.outlines",
          "group": "overflow"
        },
        {
          "command": "novelCompanion.immersive.open",
          "when": "view == novel-companion.outlines",
          "group": "overflow"
        },
        {
          "command": "novelCompanion.relationGraph.open",
          "when": "view == novel-companion.characters",
          "group": "overflow"
        },
        {
          "command": "novelCompanion.timelineViz.open",
          "when": "view == novel-companion.timeline",
          "group": "overflow"
        }
      ],
      "view/item/context": [
        {
          "command": "novelCompanion.bookshelf.open",
          "when": "view == novel-companion.bookshelf && viewItem == book",
          "group": "1@1"
        },
        {
          "command": "novelCompanion.novel.editInfo",
          "when": "view == novel-companion.novel-info && viewItem == info",
          "group": "1@1"
        },
        {
          "command": "novelCompanion.chapter.openOutline",
          "when": "view == novel-companion.outlines",
          "group": "1@1"
        },
        {
          "command": "novelCompanion.chapter.openDraft",
          "when": "view == novel-companion.outlines",
          "group": "1@2"
        },
        {
          "command": "novelCompanion.chapter.archive",
          "when": "view == novel-companion.outlines && viewItem == revising",
          "group": "2@1"
        },
        {
          "command": "novelCompanion.chapter.moveUp",
          "when": "view == novel-companion.outlines",
          "group": "2@2"
        },
        {
          "command": "novelCompanion.chapter.moveDown",
          "when": "view == novel-companion.outlines",
          "group": "2@3"
        },
        {
          "command": "novelCompanion.chapter.rename",
          "when": "view == novel-companion.outlines",
          "group": "3@1"
        },
        {
          "command": "novelCompanion.chapter.delete",
          "when": "view == novel-companion.outlines",
          "group": "3@2"
        },
        {
          "command": "novelCompanion.volume.rename",
          "when": "view == novel-companion.outlines && viewItem == volumeGroup",
          "group": "3@1"
        },
        {
          "command": "novelCompanion.volume.delete",
          "when": "view == novel-companion.outlines && viewItem == volumeGroup",
          "group": "3@2"
        },
        {
          "command": "novelCompanion.character.open",
          "when": "view == novel-companion.characters",
          "group": "1@1"
        },
        {
          "command": "novelCompanion.setting.open",
          "when": "view == novel-companion.settings",
          "group": "1@1"
        },
        {
          "command": "novelCompanion.foreshadowing.openFile",
          "when": "view == novel-companion.foreshadowing && viewItem == foreshadowPending",
          "group": "1@1"
        },
        {
          "command": "novelCompanion.foreshadowing.showReferences",
          "when": "view == novel-companion.foreshadowing && viewItem == foreshadowPending",
          "group": "1@2"
        },
        {
          "command": "novelCompanion.foreshadowing.resolve",
          "when": "view == novel-companion.foreshadowing && viewItem == foreshadowPending",
          "group": "2@1"
        },
        {
          "command": "novelCompanion.foreshadowing.openFile",
          "when": "view == novel-companion.foreshadowing && viewItem == foreshadowResolved",
          "group": "1@1"
        },
        {
          "command": "novelCompanion.foreshadowing.showReferences",
          "when": "view == novel-companion.foreshadowing && viewItem == foreshadowResolved",
          "group": "1@2"
        },
        {
          "command": "novelCompanion.snippet.open",
          "when": "view == novel-companion.snippets && viewItem == snippet",
          "group": "1@1"
        },
        {
          "command": "novelCompanion.snippet.insert",
          "when": "view == novel-companion.snippets && viewItem == snippet",
          "group": "1@2"
        },
        {
          "command": "novelCompanion.snippet.delete",
          "when": "view == novel-companion.snippets && viewItem == snippet",
          "group": "2@1"
        },
        {
          "command": "novelCompanion.trash.restore",
          "when": "view == novel-companion.trash && viewItem == trash",
          "group": "1@1"
        },
        {
          "command": "novelCompanion.trash.purge",
          "when": "view == novel-companion.trash && viewItem == trash",
          "group": "1@2"
        }
      ],
      "editor/title/context": [
        {
          "command": "novelCompanion.vault.lock",
          "when": "novelCompanion.projectLoaded && resourceLangId == markdown",
          "group": "1_novel@1"
        }
      ]
    },
    "keybindings": [
      {
        "key": "ctrl+alt+n c",
        "command": "novelCompanion.chapter.create",
        "when": "novelCompanion.projectLoaded"
      },
      {
        "key": "ctrl+alt+n h",
        "command": "novelCompanion.character.create",
        "when": "novelCompanion.projectLoaded"
      },
      {
        "key": "ctrl+alt+n s",
        "command": "novelCompanion.setting.create",
        "when": "novelCompanion.projectLoaded"
      },
      {
        "key": "ctrl+alt+r",
        "command": "novelCompanion.ai.generateTask",
        "when": "novelCompanion.projectLoaded && editorLangId == markdown"
      },
      {
        "key": "ctrl+alt+shift+r",
        "command": "novelCompanion.review.openPanel",
        "when": "novelCompanion.hasPendingReview"
      }
    ],
    "configuration": {
      "title": "笔搭",
      "properties": {
        "novelCompanion.stats.countPunctuation": {
          "type": "boolean",
          "default": true,
          "description": "字数统计是否计入标点符号"
        },
        "novelCompanion.stats.countSpaces": {
          "type": "boolean",
          "default": false,
          "description": "字数统计是否计入空格"
        },
        "novelCompanion.stats.englishWordAsOne": {
          "type": "boolean",
          "default": true,
          "description": "英文单词是否算1个字"
        },
        "novelCompanion.review.interval": {
          "type": "number",
